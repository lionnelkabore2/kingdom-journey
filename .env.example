# ============================================
# KINGDOM JOURNEY — Variables d'environnement
# ============================================
# INSTRUCTIONS :
# 1. Copie ce fichier et renomme-le en ".env.local"
# 2. Remplis chaque valeur (voir GUIDE-INSTALLATION.md)
# 3. Ne partage JAMAIS ce fichier avec personne !
# ============================================

# --- SUPABASE (Base de données) ---
# Trouve ces valeurs sur : https://supabase.com → ton projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- SÉCURITÉ ---
# Génère une clé secrète ici : https://generate-secret.vercel.app/32
JWT_SECRET=remplace_par_une_longue_chaine_secrete_aleatoire

# --- BIBLE API (gratuit) ---
# Inscription gratuite sur : https://scripture.api.bible
BIBLE_API_KEY=remplace_par_ta_cle_api_bible

# --- ANTHROPIC (Assistant Eli) ---
# Trouve ta clé sur : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# --- URL de l'application ---
# En développement local, laisse localhost
# Sur Vercel, mets l'URL de ton site (ex: https://kingdom-journey.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
